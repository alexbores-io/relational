---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import attackJan30 from '../assets/attack-text-jan30.jpg';
import attackFeb24 from '../assets/attack-text-feb24.jpg';

const interestFormHref =
  'https://docs.google.com/forms/d/e/1FAIpQLSdf88V00XmpgTET2ENB-TDrmajP_p6WJS2xfVvhpheTmNpuEg/viewform';
---
<Base title="Got friends in NY-12? Help elect Alex Bores. · alexbores.io">

  <aside class="sidebar-toc" aria-label="Section navigation">
    <p class="sidebar-prompt">sections</p>
    <ol class="sidebar-list">
      <li>
        <a href="#alex" data-section="alex">
          <span class="s-tree">├──</span>
          <span class="s-num">01</span>
          <span class="s-file">why-alex.md</span>
        </a>
      </li>
      <li>
        <a href="#strategy" data-section="strategy">
          <span class="s-tree">├──</span>
          <span class="s-num">02</span>
          <span class="s-file">our-strategy.md</span>
        </a>
        <ol class="sidebar-sublist">
          <li>
            <a href="#district" data-section="district">
              <span class="s-tree">│   ├──</span>
              <span class="s-file">the-district.md</span>
            </a>
          </li>
          <li>
            <a href="#attacks" data-section="attacks">
              <span class="s-tree">│   └──</span>
              <span class="s-file">the-attacks.md</span>
            </a>
          </li>
        </ol>
      </li>
      <li>
        <a href="#volunteer" data-section="volunteer">
          <span class="s-tree">├──</span>
          <span class="s-num">03</span>
          <span class="s-file">relational-organizing.md</span>
        </a>
      </li>
      <li>
        <a href="#dates" data-section="dates">
          <span class="s-tree">└──</span>
          <span class="s-num">04</span>
          <span class="s-file">key-dates.md</span>
        </a>
      </li>
    </ol>
  </aside>

  <p class="eyebrow">alexbores.io</p>

  <h1 class="hero">
    Got friends in NY-12? Help elect <span class="accent">Alex Bores</span>
  </h1>

  <p class="lede">
    A volunteer-run relational organizing effort, aimed at people in tech, EA, and adjacent communities.
  </p>

  <nav class="toc" aria-label="Page sections">
    <p class="toc-prompt">sections</p>
    <ol class="toc-list">
      <li>
        <a href="#alex">
          <span class="toc-tree">├──</span>
          <span class="toc-num">01</span>
          <span class="toc-file">why-alex.md</span>
          <span class="toc-desc">The RAISE Act, endorsements, vigorous opposition.</span>
        </a>
      </li>
      <li>
        <a href="#strategy">
          <span class="toc-tree">├──</span>
          <span class="toc-num">02</span>
          <span class="toc-file">our-strategy.md</span>
          <span class="toc-desc">Who we're reaching. Who's attacking him. Key dates.</span>
        </a>
        <ol class="toc-sublist">
          <li>
            <a href="#district">
              <span class="toc-tree">│   ├──</span>
              <span class="toc-file">the-district.md</span>
              <span class="toc-desc">Who lives in NY-12.</span>
            </a>
          </li>
          <li>
            <a href="#attacks">
              <span class="toc-tree">│   └──</span>
              <span class="toc-file">the-attacks.md</span>
              <span class="toc-desc">OpenAI's $10M text campaign.</span>
            </a>
          </li>
        </ol>
      </li>
      <li>
        <a href="#volunteer">
          <span class="toc-tree">├──</span>
          <span class="toc-num">03</span>
          <span class="toc-file">relational-organizing.md</span>
          <span class="toc-desc">Four ways to help, starting with friends.</span>
        </a>
      </li>
      <li>
        <a href="#dates">
          <span class="toc-tree">└──</span>
          <span class="toc-num">04</span>
          <span class="toc-file">key-dates.md</span>
          <span class="toc-desc">Registration, early voting, election day.</span>
        </a>
      </li>
    </ol>
  </nav>

  <!-- WHY ALEX -->
  <section class="block" id="alex">
    <p class="section-eyebrow">why alex?</p>
    <h2>Why Alex?</h2>
    <div class="prose">
      <p>Alex Bores is the author and sole New York Assembly sponsor of the <strong>RAISE Act</strong>, which holds frontier AI labs accountable for serious damages caused by AI. He has won endorsements from leading voices in the AI safety community<sup class="cite"><a href="/voices">[1]</a></sup>, and drawn vigorous opposition from OpenAI, Palantir, and other firms in the AI industry<sup class="cite"><a href="https://techcrunch.com/2026/03/03/ai-companies-are-spending-millions-to-thwart-this-former-tech-execs-congressional-bid/" target="_blank" rel="noopener">[2]</a></sup><sup class="cite"><a href="https://www.nytimes.com/2026/04/21/opinion/ezra-klein-podcast-alex-bores.html" target="_blank" rel="noopener">[3]</a></sup>.</p>
      <p>If you're visiting this page, you probably know all that — and you're in a great position to persuade exactly the voters in NY-12 whose support Alex needs to win.</p>
    </div>
  </section>

  <!-- OUR STRATEGY -->
  <section class="block" id="strategy">
    <p class="section-eyebrow">our strategy</p>
    <h1 class="strategy-title">Our strategy</h1>
    <h2>Win knowledge workers</h2>

    <div class="prose" id="district">
      <p>NY-12 is dense with highly-educated professionals. It's among the most highly-educated, highest-income districts in NYC and in the country:</p>
    </div>
    <div class="data-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col">Metric</th>
            <th scope="col">NY-12</th>
            <th scope="col">NYC overall</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">Bachelor's degree or higher (25+)</th>
            <td>81%</td>
            <td>42.5%</td>
          </tr>
          <tr>
            <th scope="row">Median household income</th>
            <td>$153,117</td>
            <td>$81,228</td>
          </tr>
          <tr>
            <th scope="row">Per capita income</th>
            <td>$138,927</td>
            <td>$52,504</td>
          </tr>
          <tr>
            <th scope="row">Population</th>
            <td>752,016</td>
            <td>~8.3M</td>
          </tr>
          <tr>
            <th scope="row">Poverty rate</th>
            <td>8.2%</td>
            <td>~18%</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="data-caption">Source: Census Reporter, NY-12 profile<sup class="cite"><a href="https://censusreporter.org/profiles/50000US3612-congressional-district-12-ny/" target="_blank" rel="noopener">[4]</a></sup></p>

    <h2 id="attacks">Let the attacks open the door</h2>
    <div class="prose" style="margin-bottom: 20px;">
      <p>The Leading the Future Super PAC — led by OpenAI, Palantir &amp; friends — has spent <strong>over $10 million</strong><sup class="cite"><a href="https://techcrunch.com/2026/03/03/ai-companies-are-spending-millions-to-thwart-this-former-tech-execs-congressional-bid/" target="_blank" rel="noopener">[2]</a></sup> blanketing the district with text messages like these:</p>
    </div>
    <div class="attack-grid">
      <figure class="attack-figure">
        <Image src={attackJan30} alt="SMS screenshot attacking Bores for his work at Palantir, the company that powers ICE. Paid for by Think Big PAC." class="attack-screenshot" loading="lazy" widths={[400, 600, 800]} sizes="(min-width: 640px) 380px, 100vw" />
        <figcaption class="attack-caption">Jan 30, 2026 · Think Big PAC</figcaption>
      </figure>
      <figure class="attack-figure">
        <Image src={attackFeb24} alt="SMS screenshot citing alleged Bloomberg reporting on Bores' time at Palantir. Paid for by Think Big PAC." class="attack-screenshot" loading="lazy" widths={[400, 600, 800]} sizes="(min-width: 640px) 380px, 100vw" />
        <figcaption class="attack-caption">Feb 24, 2026 · Think Big PAC</figcaption>
      </figure>
    </div>
    <div class="prose" style="margin-top: 22px;">
      <p>Some voters are persuaded by these text messages. Many voters, rightly, find them suspicious and annoying — and are more than happy to learn the truth about the ads and why it's critical to support Alex. <strong>That is where our community comes in.</strong></p>
    </div>

    <p class="see-also">
      See also <a href="/voices">voices.md</a> — press coverage and on-record commentary from Eric Neyman, Scott Alexander, Ezra Klein, and more.
    </p>
  </section>

  <!-- RELATIONAL ORGANIZING -->
  <section class="block" id="volunteer">
    <p class="section-eyebrow">relational organizing</p>
    <h2>Relational organizing</h2>

    <div class="prose" style="margin-bottom: 12px;">
      <p>This is how we can help.</p>
    </div>

    <ol class="action-list">
      <li>
        <h3>Relational organizing</h3>
        <p>Use the <a href="https://reach.vote/" target="_blank" rel="noopener">Reach app</a> to discover in-district connections. Strike up a conversation about the OpenAI-funded smear campaign. For more preparation, check out our <a href="/relational">relational organizing page</a>.</p>
      </li>
      <li>
        <h3>Posts and op-eds</h3>
        <p>In whatever communities you're active — message boards, social media, community groups — discuss the AI issue and the NY-12 election as it matters to you. See some ideas at <a href="/posts">posts.md</a>.</p>
      </li>
      <li>
        <h3>Ground game volunteering</h3>
        <p>If you live in or near the district, <a href="https://www.alexbores.nyc/" target="_blank" rel="noopener">sign up to volunteer with the campaign</a>.</p>
      </li>
      <li>
        <h3>Make a donation to Alex Bores</h3>
        <p><a href="https://www.alexbores.nyc/donate/" target="_blank" rel="noopener">Donate here</a>.</p>
      </li>
    </ol>

    <div class="cta-block" style="margin-top: 32px;">
      <a class="btn" href={interestFormHref} target="_blank" rel="noopener">
        Count me in →
      </a>
      <p class="cta-help">Short Google Form — name, location, what you're up for.</p>
    </div>
  </section>

  <!-- KEY DATES -->
  <section class="block" id="dates">
    <p class="section-eyebrow">key dates</p>
    <h2>Key dates</h2>
    <div class="dates">
      <div class="date-cell">
        <p class="date-label">Jun 13 · Saturday</p>
        <p class="date-value">Registration deadline</p>
        <p class="date-desc">Last day to register. Early voting <em>also</em> begins.</p>
      </div>
      <div class="date-cell">
        <p class="date-label">Jun 22 · Sunday</p>
        <p class="date-value">End of early voting</p>
        <p class="date-desc">Last day to vote <em>before</em> election day.</p>
      </div>
      <div class="date-cell">
        <p class="date-label">Jun 23 · Tuesday</p>
        <p class="date-value">Election day</p>
        <p class="date-desc">Polls open. Primary <em>election day</em>.</p>
      </div>
    </div>
    <div class="prose" style="margin-top: 20px;">
      <p>If you want to contact someone who isn't registered to vote in New York, they need to register by <strong>June 13</strong>. It's too late to re-register with a party affiliation, so outreach should focus on current registered Democrats and unregistered New Yorkers.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="block" id="faq">
    <p class="section-eyebrow">faq</p>
    <h2>Concerns, addressed</h2>
    <div class="faq">
      <details>
        <summary>Is this legal / okay with campaign finance rules?</summary>
        <div class="answer">
          <p>Volunteer time is fine. Spending money on this effort (merch, paid ads, etc.) can count as an in-kind contribution and needs to be reported — talk to us before spending. Professional services (design, engineering, etc.) done for the campaign need to be at market rate unless you do it as a genuine volunteer for something unrelated to your profession. None of this is legal advice; if you have a specific question, ask a lawyer.</p>
        </div>
      </details>
      <details>
        <summary>What's the campaign's involvement?</summary>
        <div class="answer">
          <p>The campaign provides guidance on messaging and best practices. They don't manage this effort, and we don't speak for them.</p>
        </div>
      </details>
      <details>
        <summary>Can I talk to the media about this?</summary>
        <div class="answer">
          <p>Please don't, by default. If you're getting press questions, forward them to us and we'll connect you to someone appropriate.</p>
        </div>
      </details>
      <details>
        <summary>What if Bores loses?</summary>
        <div class="answer">
          <p>He might — this is a competitive primary. We're being upfront about that. The case for trying is that a few hours of your time has a real probability of moving the outcome, and either way you'll have had honest conversations with people you care about.</p>
        </div>
      </details>
      <details>
        <summary>How do you keep contacts from being messaged by ten different people?</summary>
        <div class="answer">
          <p>There's a shared tracker of who's reached out to whom. When you sign up, you get assigned specific contacts and we coordinate to avoid the pile-on problem.</p>
        </div>
      </details>
      <details>
        <summary>What if I don't want to message friends?</summary>
        <div class="answer">
          <p>Totally fine — plenty of other ways to help, see the list above. Mention it in the email and we'll skip straight to something else.</p>
        </div>
      </details>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.sidebar-list a[data-section]');
  const linkById = new Map<string, HTMLAnchorElement>();
  links.forEach((l) => {
    const id = l.dataset.section;
    if (id) linkById.set(id, l);
  });

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          links.forEach((l) => l.classList.remove('active'));
          const link = linkById.get(entry.target.id);
          if (link) link.classList.add('active');
        }
      }
    },
    { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
  );

  ['alex', 'strategy', 'district', 'attacks', 'dates', 'volunteer'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>
